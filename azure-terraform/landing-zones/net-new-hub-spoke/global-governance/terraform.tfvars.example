management_group_budgets = {
  nonprod_monthly = {
    management_group_key = "compeer-lz-nonprod"
    amount               = 25000
    time_grain           = "Monthly"
    time_period = {
      start_date = "2026-07-01T00:00:00Z"
    }
    notifications = {
      actual_80 = {
        threshold      = 80
        operator       = "GreaterThan"
        threshold_type = "Actual"
        contact_emails = ["cloudops@compeer.example"]
      }
      forecast_100 = {
        threshold      = 100
        operator       = "GreaterThan"
        threshold_type = "Forecasted"
        contact_emails = ["cloudops@compeer.example"]
      }
    }
  }
}
