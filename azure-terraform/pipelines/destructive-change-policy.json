{
  "default_impact": "medium",
  "impact": {
    "low": {
      "description": "Expected or generated replacements that should be visible but should not block normal delivery.",
      "resource_types": [
        "azurerm_monitor_diagnostic_setting",
        "azurerm_application_insights_web_test",
        "azurerm_monitor_metric_alert",
        "azurerm_monitor_scheduled_query_rules_alert",
        "azurerm_monitor_action_group"
      ],
      "address_patterns": [
        "private.*endpoint.*network.*interface",
        "private.*endpoint.*nic",
        "generated",
        "diagnostic"
      ]
    },
    "medium": {
      "description": "Application or attachment resources where replacement is often legitimate but must be acknowledged in the PR.",
      "resource_types": [
        "azurerm_app_service_slot",
        "azurerm_linux_web_app_slot",
        "azurerm_windows_web_app_slot",
        "azurerm_function_app_slot",
        "azurerm_linux_function_app_slot",
        "azurerm_windows_function_app_slot",
        "azurerm_private_endpoint",
        "azurerm_role_assignment",
        "azurerm_app_service_virtual_network_swift_connection",
        "azurerm_subnet_network_security_group_association",
        "azurerm_subnet_route_table_association",
        "azurerm_nat_gateway_subnet_association",
        "azurerm_network_interface_application_security_group_association",
        "azurerm_network_interface_backend_address_pool_association",
        "azurerm_private_dns_a_record",
        "azurerm_private_dns_zone_virtual_network_link",
        "azurerm_key_vault_secret",
        "azurerm_key_vault_key",
        "azurerm_key_vault_certificate",
        "azurerm_storage_blob",
        "azurerm_storage_container",
        "azurerm_storage_queue",
        "azurerm_storage_share",
        "azurerm_storage_table"
      ],
      "address_patterns": [
        "slot",
        "private_endpoint",
        "role_assignment",
        "subnet_.*association",
        "association"
      ]
    },
    "high": {
      "description": "Platform, data, network, identity, and security resources where replacement can cause outage, data loss, or control-plane drift.",
      "resource_types": [
        "azurerm_storage_account",
        "azurerm_key_vault",
        "azurerm_mssql_database",
        "azurerm_mssql_server",
        "azurerm_sql_database",
        "azurerm_sql_server",
        "azurerm_virtual_network",
        "azurerm_subnet",
        "azurerm_route_table",
        "azurerm_network_security_group",
        "azurerm_nat_gateway",
        "azurerm_public_ip",
        "azurerm_firewall",
        "azurerm_firewall_policy",
        "azurerm_application_gateway",
        "azurerm_api_management",
        "azurerm_service_plan",
        "azurerm_linux_function_app",
        "azurerm_windows_function_app",
        "azurerm_linux_web_app",
        "azurerm_windows_web_app",
        "azurerm_user_assigned_identity",
        "azurerm_role_definition",
        "azurerm_policy_assignment",
        "azurerm_policy_definition",
        "azurerm_management_group_policy_assignment",
        "azurerm_resource_group_policy_assignment",
        "azurerm_subscription_policy_assignment",
        "azurerm_management_group",
        "azurerm_subscription",
        "azurerm_resource_group",
        "azurerm_log_analytics_workspace",
        "azurerm_recovery_services_vault",
        "azurerm_backup_policy_vm",
        "azurerm_kubernetes_cluster",
        "azurerm_servicebus_namespace",
        "azurerm_eventhub_namespace",
        "azurerm_cosmosdb_account",
        "azurerm_postgresql_flexible_server",
        "azurerm_mysql_flexible_server",
        "azurerm_synapse_workspace"
      ],
      "address_patterns": [
        "prod",
        "production",
        "identity",
        "security",
        "policy",
        "firewall",
        "route",
        "vnet",
        "subnet",
        "key_vault",
        "storage_account",
        "sql"
      ]
    }
  }
}
